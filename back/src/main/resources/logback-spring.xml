<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!--
      Producción (Docker): un archivo activo + histórico por día (retención 30 días).
      Requiere /app/logs escribible por el usuario del proceso (ver docker-entrypoint.sh).
    -->
    <springProfile name="prod">
        <springProperty name="LOG_PATH" source="logging.file.path" defaultValue="/app/logs"/>
        <springProperty name="LOG_FILE" source="logging.file.name" defaultValue="seguridadallimite.log"/>
        <springProperty name="ROOT_LEVEL" source="logging.level.root" defaultValue="WARN"/>
        <springProperty name="APP_LEVEL" source="logging.level.com.seguridadlimite" defaultValue="INFO"/>

        <logger name="com.seguridadlimite" level="${APP_LEVEL}"/>

        <appender name="ROLLING_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/${LOG_FILE}</file>
            <encoder>
                <charset>UTF-8</charset>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{40} - %msg%n</pattern>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/seguridadallimite.%d{yyyy-MM-dd}.log</fileNamePattern>
                <maxHistory>30</maxHistory>
                <totalSizeCap>2GB</totalSizeCap>
                <cleanHistoryOnStart>false</cleanHistoryOnStart>
            </rollingPolicy>
        </appender>

        <root level="${ROOT_LEVEL}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ROLLING_FILE"/>
        </root>
    </springProfile>

    <!-- Desarrollo y otros perfiles: solo consola (evita permisos y duplicar FILE de Boot). -->
    <springProfile name="!prod">
        <springProperty name="ROOT_LEVEL" source="logging.level.root" defaultValue="INFO"/>
        <root level="${ROOT_LEVEL}">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>
</configuration>
