				<box>
					<topPen lineWidth="0.25" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="0.25" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="0.25" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="0.25" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement>
					<font size="7"/>
				</textElement>
				<text><![CDATA[2.Indiquenos del 1 al 5 (donde 1 es malo y 5 es excelente) ¿Nuestro personal se mostro de manera cortes y amable?]]></text>
			</staticText>
			<staticText>
				<reportElement x="292" y="513" width="288" height="17" uuid="d21651fa-2573-4b2c-ac0e-71437a6146da"/>
				<textElement>
					<font size="7"/>
				</textElement>
				<text><![CDATA[1.1 Que le parecen los contenidos del curso?]]></text>
			</staticText>
			<staticText>
				<reportElement x="290" y="532" width="291" height="18" uuid="ae7eff2a-4de4-4ec0-af8c-ec6dd710b6b3"/>
				<textElement>
					<font size="7"/>
				</textElement>
