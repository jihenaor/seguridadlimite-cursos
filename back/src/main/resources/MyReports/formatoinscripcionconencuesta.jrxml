	<variable name="consentimiento" class="java.lang.String">
		<variableExpression><![CDATA["El diligenciamiento de este formato es voluntario, se solicita para trámites y requerimiento legales en la formación y entrenamiento en protección contra caídas para trabajo en alturas.  Yo "
+ $F{nombrecompleto}.toString() 
+ "identificado(a) con documento de Identidad No. " + $F{numerodocumento}.toString() 
+ ", voluntariamente y en pleno uso de mis facultades autorizo al centro de formación y entrenamiento en protección contra caídas para trabajo en alturas SEGURIDAD AL LIMITE S.A.S a conocer mi datos personales y condiciones de salud necesaria y aplicada en el presente formato."]]></variableExpression>
	</variable>
