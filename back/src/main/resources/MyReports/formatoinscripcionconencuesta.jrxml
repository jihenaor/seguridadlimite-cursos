	<variable name="aceptacion" class="java.lang.String">
		<variableExpression><![CDATA["Yo:" + $F{nombrecompleto}
+ "Identificado(a) con documento de Identidad No." 
+ $F{numerodocumento} 
+ "voluntariamente y en pleno uso de mis facultades, acepto conocer y cumplir el codigo de buen comportamiento y codigo de etica establecido en proteccion contra caidas para trabajo en alturas SEGURIDAD AL LIMITE SAS. "
+ "Adicionalmente certifico que he recibido socializacion de la matriz de riesgos, plan de emergencias, e informacion sobre el buen uso de equipos y las instalaciones."]]></variableExpression>
	</variable>
