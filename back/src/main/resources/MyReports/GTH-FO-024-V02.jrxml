	<variable name="aceptacion" class="java.lang.String">
		<expression><![CDATA["YO"]]></expression>
		<initialValueExpression><![CDATA["YO" +
($F{nombreaprendiz} != null ? $F{nombreaprendiz}.toString() : "") +
" identificado(a) con documento de Identidad No. " +
($F{numerodocumento} != null ? $F{numerodocumento}.toString() : "") +
", voluntariamente y en pleno uso de mis facultades, " +
"acepto conocer y cumplir el código de buen comportamiento y código de ética, establecido por el centro de formación y entrenamiento en protección contra caídas para trabajo " +
"en alturas SEGURIDAD AL LIMITE S.A.S. <br /><br />" +
"Adicionalmente certifico que he recibido socialización de la matriz de riesgos, plan de emergencias, e información sobre el buen uso de equipos y de las instalaciones."]]></initialValueExpression>
	</variable>
