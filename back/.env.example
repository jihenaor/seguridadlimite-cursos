# ─────────────────────────────────────────────────────────────────────
#  Variables de entorno — Backend (desarrollo local)
#  Copia como .env en esta carpeta (back/) y ajusta valores.
#
#  La API debe conectarse con DB_USER / DB_PASSWORD (cuenta de aplicación).
#  MYSQL_ROOT_PASSWORD solo aplica al contenedor MySQL (administración), no la uses en Spring.
#
#  Docker (desde back/): docker compose up -d
#  Maven (JDK 21):  .\mvn-java21.cmd spring-boot:run   (si mvnw falla con "release 21 not supported")
# ─────────────────────────────────────────────────────────────────────

# Base de datos — mismo usuario que MYSQL_USER en docker-compose.yml del back
DB_HOST=localhost
DB_PORT=3306
DB_NAME=wwsegu_cursos
DB_USER=seguridadlimite_app
DB_PASSWORD=DevAppDb_Local_ChangeMe

# Solo para docker compose (usuario root del servidor MySQL en el contenedor)
MYSQL_ROOT_PASSWORD=DevRootOnly_ChangeMe

# Correo (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=

# JWT — genera la clave con: openssl rand -base64 32
JWT_SECRET=REEMPLAZA_CON_CLAVE_ALEATORIA_BASE64_256_BITS
JWT_EXPIRATION_MINUTES=30

# Token de despliegue (genera con: openssl rand -hex 32)
DEPLOY_SECRET_TOKEN=REEMPLAZA_CON_TOKEN_ALEATORIO_HEX_64_CHARS