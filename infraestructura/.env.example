# ─────────────────────────────────────────────────────────────────────
#  Variables de entorno — Infraestructura Seguridad Al Límite
#  Copia este archivo como .env y completa los valores reales.
#  NUNCA comitas el archivo .env (ya está en .gitignore).
#
#  Uso:
#    cp .env.example .env
#    nano .env
#    docker compose up -d
# ─────────────────────────────────────────────────────────────────────

# ── GitHub Container Registry ─────────────────────────────────────────
GITHUB_ORG=tu-organizacion-github

# ── Tags de imagen (usar 'latest' en dev, SHA en prod) ───────────────
BACKEND_TAG=latest
FRONTEND_TRABAJADOR_TAG=latest
FRONTEND_ADMIN_TAG=latest

# ── Base de datos ─────────────────────────────────────────────────────
#  Root: solo administración / emergencias. El backend usa siempre DB_USER (no root).
MYSQL_ROOT_PASSWORD=REEMPLAZA_CON_PASSWORD_ROOT_FUERTE
DB_NAME=wwsegu_cursos
DB_USER=seguridadlimite_app
DB_PASSWORD=REEMPLAZA_CON_PASSWORD_DB_FUERTE
# Conexión desde Maven en el host hacia MySQL del compose (puerto publicado en 127.0.0.1:3306)
DB_HOST=localhost
DB_PORT=3306

# ── phpMyAdmin (docker compose) ───────────────────────────────────────
#  Tras `docker compose up -d`: http://127.0.0.1:8080
#  Uso habitual: entra con DB_USER / DB_PASSWORD. Root solo si necesitas tareas de DBA.

# ── JWT ───────────────────────────────────────────────────────────────
# Genera la clave con: openssl rand -base64 32
JWT_SECRET=REEMPLAZA_CON_CLAVE_BASE64_256_BITS
JWT_EXPIRATION_MINUTES=30

# ── Correo SMTP ───────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu_correo@gmail.com
MAIL_PASSWORD=tu_app_password_gmail

# ── Token de despliegue ───────────────────────────────────────────────
# Genera con: openssl rand -hex 32
DEPLOY_SECRET_TOKEN=REEMPLAZA_CON_TOKEN_HEX_64_CHARS

# ── Almacenamiento de archivos en el backend (fotos, firmas, documentos, certificados) ─
# En Docker los valores por defecto apuntan a /app/storage/* (volumen backend_storage).
# Opcional: rutas absolutas en el host si montas bind-mount en lugar del volumen nombrado.
# PATH_FOTOS=/app/storage/fotos/
# PATH_FOTOS_WIN=   (solo Windows nativo; en contenedor Linux no aplica)
# APP_FOTO_MAX_EDGE_PX=960
# APP_FOTO_JPEG_QUALITY=0.82
#
# Backup semanal (contenedor backup): incluye copia del volumen de archivos si defines:
#   docker volume ls | grep backend_storage
# BACKEND_STORAGE_VOLUME=infraestructura_backend_storage
# Documentación: infraestructura/docs/almacenamiento-y-backup-archivos.md

# ── Gateway ───────────────────────────────────────────────────────────
# Puerto externo del gateway (80 redirige a 443 automáticamente)
GATEWAY_PORT=80
