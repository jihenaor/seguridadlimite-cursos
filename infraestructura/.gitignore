# ─────────────────────────────────────────────
#  .gitignore — Infraestructura / Docker
# ─────────────────────────────────────────────

# ══ ARCHIVOS SENSIBLES — NUNCA subir ══════════
.env
.env.*
!.env.example
set_env.bat

# ══ LOGS ══════════════════════════════════════
*.log
*.log.*.gz
logs/

# ══ CERTIFICADOS SSL (generados por certbot) ══
nginx/certs/
letsencrypt/
certbot/

# ══ SCRIPTS SSL (generados localmente) ══
*ssl.sh
*.bak

# ══ SISTEMA OPERATIVO ══════════════════════════
.DS_Store
Thumbs.db
