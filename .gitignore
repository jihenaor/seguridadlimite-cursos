# ─────────────────────────────────────────────────────────────
#  .gitignore — Seguridad Al Límite (monorepo raíz)
# ─────────────────────────────────────────────────────────────

# ══ ARCHIVOS SENSIBLES — NUNCA subir ══════════════════════════
**/.env
**/.env.local
**/.env.production
**/set_env.bat
# NOTA: application-prod.yml SÍ se commitea (usa ${ENV_VAR}, sin credenciales)
# NOTA: application.yml SÍ se commitea (usa valores de desarrollo seguros)

# ══ BACK-END (Maven / Java) ═══════════════════════════════════
back/target/
!back/.mvn/wrapper/maven-wrapper.jar
**/*.class

# ══ FRONT-END (Angular / Node) ════════════════════════════════
front/node_modules/
front/dist/
front/.angular/
front/coverage/

# ══ LANDING PAGE ══════════════════════════════════════════════
landingpage/node_modules/
landingpage/dist/
landingpage/.angular/

# ══ MICROFRONTENDS (obsoleto — eliminado del proyecto) ════════
microfrontends/

# ══ LOGS ══════════════════════════════════════════════════════
*.log
*.log.*.gz
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ══ IDEs ══════════════════════════════════════════════════════
.idea/
.vscode/
*.iml
*.suo
*.user
*.swp

# ══ SISTEMA OPERATIVO ══════════════════════════════════════════
.DS_Store
Thumbs.db
nul
desktop.ini

# ══ DOCKER (artefactos locales) ════════════════════════════════
**/.docker/

# ══ DOCUMENTOS DE ANÁLISIS (no son código fuente) ═════════════
*.docx
*.pdf
